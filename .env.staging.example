# Staging Environment Variables for LIFO AI FastAPI Backend
# Copy this file to .env.staging and fill in the values
# This is for STAGING/TESTING environment - separate from production

# =============================================================================
# APPLICATION SETTINGS - STAGING
# =============================================================================
ENVIRONMENT=staging
DEBUG=true
API_V1_STR=/api/v1
PROJECT_NAME=LIFO AI API - Staging

# Server Configuration  
HOST=0.0.0.0
PORT=8080

# =============================================================================
# SECURITY SETTINGS - STAGING
# =============================================================================
# Generate different key for staging: openssl rand -hex 32
SECRET_KEY=staging-secret-key-different-from-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8 hours for easier testing

# =============================================================================
# DATABASE CONFIGURATION - STAGING
# =============================================================================
# Staging Database URL (separate from production)
DATABASE_URL=postgresql://staging_user:staging_password@staging_host:port/staging_dbname

# Database Pool Settings (smaller for staging)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# =============================================================================
# SUPABASE CONFIGURATION - STAGING
# =============================================================================
# Option 1: Same Supabase project but different environment
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Option 2: Separate Supabase project for staging (recommended)
# SUPABASE_URL=https://your-staging-project.supabase.co
# SUPABASE_ANON_KEY=your-staging-project-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-staging-project-service-role-key

# =============================================================================
# CORS & FRONTEND CONFIGURATION - STAGING
# =============================================================================
# More permissive CORS for testing
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://staging-domain.com,https://preview-*.vercel.app,https://*.netlify.app
FRONTEND_URL=https://staging-domain.com
API_URL=https://staging-api-domain.ondigitalocean.app

# =============================================================================
# TESTING & DEBUG CONFIGURATION
# =============================================================================
# Enable additional endpoints for testing
ENABLE_TEST_ENDPOINTS=true
ENABLE_DEBUG_ROUTES=true

# Mock external services for isolated testing
MOCK_EXTERNAL_SERVICES=false
MOCK_GOOGLE_VISION=false
MOCK_SUPABASE_AUTH=false

# =============================================================================
# GOOGLE CLOUD CONFIGURATION - STAGING
# =============================================================================
# Staging Google Cloud credentials (can be same as prod or separate)
GOOGLE_APPLICATION_CREDENTIALS_JSON=base64-encoded-staging-service-account-json

# =============================================================================
# REDIS CONFIGURATION - STAGING
# =============================================================================
# Optional: Separate Redis instance for staging
REDIS_URL=redis://staging_user:staging_password@staging_host:port/staging_db

# =============================================================================
# MONITORING & LOGGING - STAGING
# =============================================================================
LOG_LEVEL=DEBUG
SENTRY_DSN=https://staging-sentry-dsn@sentry.io/staging-project-id

# Detailed logging for debugging
ENABLE_SQL_LOGGING=true
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true

# =============================================================================
# PERFORMANCE SETTINGS - STAGING
# =============================================================================
# Reduced workers for staging
WORKERS=1
MAX_WORKERS=2

# Rate limiting (more lenient for testing)
RATE_LIMIT_PER_MINUTE=200
RATE_LIMIT_BURST=50

# =============================================================================
# TEST DATA & SEEDING
# =============================================================================
# Automatic test data seeding
SEED_TEST_DATA=true
TEST_STORE_ID=test-store-uuid
TEST_USER_ID=test-user-uuid

# Sample data settings
CREATE_SAMPLE_PRODUCTS=true
CREATE_SAMPLE_BATCHES=true
CREATE_SAMPLE_USERS=false  # Don't create users automatically

# =============================================================================
# FEATURE FLAGS - STAGING
# =============================================================================
# Enable experimental features in staging
ENABLE_EXPERIMENTAL_FEATURES=true
ENABLE_BULK_OPERATIONS=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_CSV_VALIDATION_V2=true

# =============================================================================
# DIGITAL OCEAN SPECIFIC - STAGING
# =============================================================================
# These are automatically set by Digital Ocean App Platform
# _APP_NAME=lifo-ai-api-staging
# _IS_STAGING=true