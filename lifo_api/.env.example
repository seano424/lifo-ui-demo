# LIFO AI Engine Environment Configuration
# SECURITY WARNING: This is a template file with placeholder values
# 1. Copy this file to .env.local 
# 2. Replace ALL placeholder values with actual credentials
# 3. DO NOT commit .env.local with real credentials
# 4. Add .env.local to .gitignore

# Application Settings
APP_NAME=LIFO AI Engine
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Development URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# CORS Settings (Development - can be overridden)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Security
SECRET_KEY=YOUR_SECRET_KEY_REPLACE_THIS_WITH_SECURE_RANDOM_STRING
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration  
DATABASE_URL=postgresql+asyncpg://YOUR_USERNAME:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DATABASE
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scoring Configuration
SCORING_WEIGHTS_EXPIRY=0.5
SCORING_WEIGHTS_VELOCITY=0.3
SCORING_WEIGHTS_MARGIN=0.2

# Cache Configuration (optional)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# Monitoring (optional)
ENABLE_METRICS=false
METRICS_PORT=9090

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=csv,xlsx

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@lifoai.com

# Webhooks (optional)
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30