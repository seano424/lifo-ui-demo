# =============================================================================
# LIFO AI Engine - Test Environment Configuration
# =============================================================================
# This file contains environment variables specifically for testing
# It ensures complete isolation from production and development environments

# =============================================================================
# ENVIRONMENT IDENTIFICATION
# =============================================================================
ENVIRONMENT=testing
DEBUG=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Use SQLite in-memory database for fast, isolated testing
DATABASE_URL=sqlite+aiosqlite:///:memory:
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Test Supabase Configuration (Mock/Test values)
SUPABASE_URL=https://test.supabase.co
SUPABASE_JWT_SECRET=test-jwt-secret-key-for-testing-only-12345678901234567890
SUPABASE_ANON_KEY=test-anon-key-for-testing-only-12345678901234567890abcdef
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key-for-testing-only-12345678901234567890abcdef

# JWT Configuration for Testing
JWT_SECRET_KEY=test-jwt-secret-key-for-testing-only-12345678901234567890
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_VERSION=1.0.0
API_V1_PREFIX=/api/v1
HOST=127.0.0.1
PORT=8000

# =============================================================================
# CORS & SECURITY SETTINGS (TESTING MODE)
# =============================================================================
# Relaxed CORS for testing
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://testserver
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Disable security features for easier testing
ENABLE_API_KEY_AUTH=false
API_KEYS=

# =============================================================================
# RATE LIMITING (DISABLED FOR TESTING)
# =============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=10000

# =============================================================================
# PERFORMANCE & MONITORING (DISABLED FOR TESTING)
# =============================================================================
ENABLE_PERFORMANCE_MONITORING=false
ENABLE_DETAILED_REQUEST_LOGGING=false
ENABLE_ALERTING=false

# Performance thresholds (for performance tests)
MOBILE_RESPONSE_TIME_CRITICAL_MS=200
MOBILE_RESPONSE_TIME_WARNING_MS=150
API_RESPONSE_TIME_WARNING_MS=500
API_RESPONSE_TIME_CRITICAL_MS=1000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# =============================================================================
# FILE PROCESSING & LIMITS
# =============================================================================
# Reduced limits for faster testing
MAX_FILE_SIZE_MB=10
MAX_CONCURRENT_OPERATIONS=5
BATCH_PROCESSING_SIZE=100
ASYNC_TIMEOUT_SECONDS=5

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Disable Redis for testing - use in-memory cache
REDIS_URL=
CACHE_TTL_SECONDS=60

# =============================================================================
# SCORING CONFIGURATION
# =============================================================================
# Default scoring weights for testing
DEFAULT_SCORING_WEIGHTS={"expiry": 0.5, "velocity": 0.3, "margin": 0.2}

# Category-specific weights
CATEGORY_WEIGHTS={"fresh_produce": {"expiry": 0.6, "velocity": 0.25, "margin": 0.15}, "dairy": {"expiry": 0.45, "velocity": 0.35, "margin": 0.2}, "bakery_fresh": {"expiry": 0.55, "velocity": 0.25, "margin": 0.2}, "meat_fish": {"expiry": 0.65, "velocity": 0.2, "margin": 0.15}, "frozen": {"expiry": 0.2, "velocity": 0.5, "margin": 0.3}}

# =============================================================================
# EXTERNAL SERVICES (DISABLED FOR TESTING)
# =============================================================================
# Weather API (disabled for testing)
WEATHER_API_KEY=
WEATHER_API_URL=http://api.openweathermap.org/data/2.5

# Google Vision API (disabled for testing)
GOOGLE_VISION_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# MOBILE CONFIGURATION
# =============================================================================
# Mobile-specific settings for testing
MAX_REQUEST_SIZE_MB=50

# =============================================================================
# TESTING FRAMEWORK CONFIGURATION
# =============================================================================
# Test-specific flags
TESTING_MODE=true
SKIP_AUTH_IN_TESTS=true
MOCK_EXTERNAL_SERVICES=true
USE_TEST_DATABASE=true

# =============================================================================
# DEPLOYMENT AUTHENTICATION (DISABLED FOR TESTING)
# =============================================================================
SUPABASE_SERVICE_EMAIL=
SUPABASE_SERVICE_PASSWORD=
DEV_USER_EMAIL=
DEV_USER_PASSWORD=
MANUAL_ACCESS_TOKEN=
STAGING_USER_EMAIL=
STAGING_USER_PASSWORD=

# =============================================================================
# PRODUCTION URLs (NOT USED IN TESTING)
# =============================================================================
FRONTEND_URL=
API_URL=

# =============================================================================
# ALERTING CONFIGURATION (DISABLED FOR TESTING)
# =============================================================================
ALERT_COOLDOWN_MINUTES=1
ALERT_ESCALATION_MINUTES=2
MAX_ALERTS_PER_TYPE_PER_HOUR=100

# System resource monitoring thresholds (relaxed for testing)
MEMORY_USAGE_WARNING_PERCENT=95
MEMORY_USAGE_CRITICAL_PERCENT=98
DISK_USAGE_WARNING_PERCENT=95
CPU_USAGE_WARNING_PERCENT=95

# =============================================================================
# PERFORMANCE MONITORING RETENTION (MINIMAL FOR TESTING)
# =============================================================================
PERFORMANCE_MONITORING_RETENTION_HOURS=1

# =============================================================================
# END OF TEST CONFIGURATION
# =============================================================================
# This configuration ensures:
# 1. Complete isolation from production/development
# 2. Fast test execution with in-memory database
# 3. Disabled external dependencies and monitoring
# 4. Relaxed security for easier test setup
# 5. Reduced resource limits for faster testing
# =============================================================================