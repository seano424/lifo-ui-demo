#!/usr/bin/env python3
"""
Test script to verify bulk scoring performance fix.

Run from lifo_api directory:
    python3 test_bulk_scoring_fix.py
"""

import asyncio
import os
import sys
import time
from datetime import datetime

async def test_database_connections():
    """Test both pooler and direct database connections."""
    from dotenv import load_dotenv
    
    env_path = os.path.join(os.path.dirname(__file__), '..', '.env.local')
    load_dotenv(env_path)
    
    print("=" * 80)
    print("🔍 DATABASE CONNECTION DIAGNOSTIC")
    print("=" * 80)
    
    database_url = os.getenv('DATABASE_URL')
    direct_url = os.getenv('DATABASE_DIRECT_URL')
    
    print(f"\n📋 Environment Variables:")
    print(f"   DATABASE_URL: {'✅ SET' if database_url else '❌ MISSING'}")
    print(f"   DATABASE_DIRECT_URL: {'✅ SET' if direct_url else '❌ MISSING'}")
    
    if not direct_url:
        print("\n❌ CRITICAL: DATABASE_DIRECT_URL is not set!")
        print("   Add to .env.local:")
        print("   DATABASE_DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres")
        return False
    
    try:
        import asyncpg
    except ImportError:
        print("\n❌ asyncpg not installed. Install with: pip install asyncpg")
        return False
    
    print("\n" + "=" * 80)
    print("🔌 Testing Direct Connection (Port 5432)")
    print("=" * 80)
    
    clean_url = direct_url.replace('+asyncpg://', '://')
    
    try:
        start = time.perf_counter()
        conn = await asyncpg.connect(clean_url, timeout=10)
        connect_time = (time.perf_counter() - start) * 1000
        
        version = await conn.fetchval('SELECT version()')
        
        # Test temp table support
        await conn.execute('CREATE TEMP TABLE test_temp (id INT)')
        await conn.execute('DROP TABLE test_temp')
        
        await conn.close()
        
        print(f"✅ Connection successful ({connect_time:.0f}ms)")
        print(f"✅ PostgreSQL: {version.split(',')[0]}")
        print(f"✅ Temp tables: SUPPORTED")
        print(f"✅ Ready for COPY operations")
        
        return True
        
    except Exception as e:
        print(f"❌ Connection failed: {str(e)}")
        print("\n🔧 Troubleshooting:")
        print("   1. Check Supabase project status")
        print("   2. Verify credentials in DATABASE_DIRECT_URL")
        print("   3. Test from Windows PowerShell if using WSL")
        return False


async def main():
    print("\n🏥 LIFO BULK SCORING CONNECTION TEST")
    print(f"Timestamp: {datetime.now().isoformat()}\n")
    
    connection_ok = await test_database_connections()
    
    if connection_ok:
        print("\n✅ DIAGNOSTIC PASSED - Ready for bulk scoring")
    else:
        print("\n❌ DIAGNOSTIC FAILED - Fix issues above")
    
    print("\n" + "=" * 80)


if __name__ == "__main__":
    asyncio.run(main())
