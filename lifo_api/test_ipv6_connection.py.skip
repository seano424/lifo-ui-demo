#!/usr/bin/env python3
"""
Test IPv6 database connection
Supabase direct database appears to be IPv6-only
"""

import asyncio
import os
import socket
import sys
from pathlib import Path

import asyncpg
from dotenv import load_dotenv

# Load environment variables
env_path = Path(__file__).parent.parent / ".env.local"
load_dotenv(env_path)


async def test_ipv6_connection():
    """Test direct connection using IPv6"""

    print("=" * 80)
    print("IPv6 DATABASE CONNECTION TEST")
    print("=" * 80)

    password = os.getenv("SUPABASE_DB_PASSWORD")
    hostname = "db.jrgmetdsohowtxickqij.supabase.co"

    print(f"\n🔍 Step 1: Checking IPv4 vs IPv6 availability")

    # Get all addresses
    try:
        addr_info = socket.getaddrinfo(
            hostname, 5432,
            socket.AF_UNSPEC,  # Allow both IPv4 and IPv6
            socket.SOCK_STREAM
        )

        ipv4_addrs = [info[4][0] for info in addr_info if info[0] == socket.AF_INET]
        ipv6_addrs = [info[4][0] for info in addr_info if info[0] == socket.AF_INET6]

        print(f"\n   IPv4 addresses: {ipv4_addrs if ipv4_addrs else 'None'}")
        print(f"   IPv6 addresses: {ipv6_addrs if ipv6_addrs else 'None'}")

        if not ipv4_addrs and ipv6_addrs:
            print("\n   🔴 DIAGNOSIS: Database is IPv6-ONLY")
            print("   This explains the connection failure!")

    except Exception as e:
        print(f"   ❌ Error: {e}")
        return False

    # Test IPv6 support in Python/system
    print(f"\n🔍 Step 2: Checking IPv6 support")

    ipv6_supported = socket.has_ipv6
    print(f"   Python IPv6 support: {ipv6_supported}")

    if ipv6_supported:
        # Try to create IPv6 socket
        try:
            test_sock = socket.socket(socket.AF_INET6, socket.SOCK_STREAM)
            test_sock.close()
            print(f"   IPv6 socket creation: ✅ Success")
        except Exception as e:
            print(f"   IPv6 socket creation: ❌ Failed ({e})")
            print(f"\n   🔴 WSL IPv6 NOT CONFIGURED")
            ipv6_supported = False

    if not ipv6_supported:
        print("\n" + "=" * 80)
        print("🔴 IPv6 NOT AVAILABLE")
        print("=" * 80)
        print("\nThe Supabase direct database requires IPv6, but:")
        print("- WSL doesn't have IPv6 enabled/configured")
        print("- This is a WSL limitation, not a code issue")
        print("\nSOLUTIONS:")
        print("1. Enable IPv6 in WSL:")
        print("   https://github.com/microsoft/WSL/issues/6977")
        print("\n2. Use pooler connection (works perfectly):")
        print("   DATABASE_URL (port 6543) - IPv4 compatible")
        print("\n3. Test from production (likely has IPv6):")
        print("   Deploy and test - direct connection may work there")
        return False

    # Try connecting with explicit IPv6
    print(f"\n🔍 Step 3: Attempting IPv6 database connection")

    if not ipv6_addrs:
        print("   ❌ No IPv6 address available")
        return False

    ipv6_addr = ipv6_addrs[0]
    print(f"   Using IPv6 address: {ipv6_addr}")

    try:
        # Connect using IPv6 address directly
        conn = await asyncpg.connect(
            user="postgres",
            password=password,
            host=ipv6_addr,  # Use IPv6 address directly
            port=5432,
            database="postgres",
            ssl='require',
            statement_cache_size=0,
            timeout=10
        )

        result = await conn.fetchval("SELECT 1")
        version = await conn.fetchval("SELECT version()")
        await conn.close()

        print(f"\n   ✅ IPv6 connection successful!")
        print(f"   Database version: {version[:80]}...")

        print("\n" + "=" * 80)
        print("✅ SUCCESS: Direct connection works with IPv6!")
        print("=" * 80)
        print("\nThis means:")
        print("- Supabase direct database is IPv6-only")
        print("- Connection works when IPv6 is properly configured")
        print("- WSL IPv6 configuration is working!")
        print("\nTo use in production:")
        print("- Ensure production environment supports IPv6")
        print("- DATABASE_DIRECT_URL should work in IPv6-enabled environments")

        return True

    except Exception as e:
        print(f"\n   ❌ Connection failed: {type(e).__name__}: {e}")
        print("\n   This confirms WSL IPv6 is not working properly")
        return False


if __name__ == "__main__":
    try:
        success = asyncio.run(test_ipv6_connection())
        sys.exit(0 if success else 1)
    except KeyboardInterrupt:
        print("\n\n⚠️  Test interrupted\n")
        sys.exit(1)
    except Exception as e:
        print(f"\n\n❌ Test failed: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
