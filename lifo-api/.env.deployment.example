# Deployment Authentication Configuration
# Copy this to .env.local and fill in appropriate values

# Basic Supabase Config (already in your .env.local)
SUPABASE_URL=https://jrgmetdsohowtxickqij.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# Production Authentication (choose one)
# Option 1: Service account credentials
SUPABASE_SERVICE_EMAIL=service-account@yourdomain.com
SUPABASE_SERVICE_PASSWORD=secure_password

# Development Authentication
# Option 1: Development user credentials
DEV_USER_EMAIL=dev@yourdomain.com
DEV_USER_PASSWORD=dev_password

# Option 2: Manual token (temporary - for current situation)
MANUAL_ACCESS_TOKEN=your_extracted_token_here

# Staging Authentication
STAGING_USER_EMAIL=staging@yourdomain.com
STAGING_USER_PASSWORD=staging_password

# Environment
ENVIRONMENT=development  # or staging, production