# LIFO AI Core Environment Variables

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/lifo_db
SUPABASE_DB_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Application Settings
LIFO_LOG_LEVEL=INFO
LIFO_DEBUG=True
LIFO_ENVIRONMENT=development
LIFO_MAX_CSV_ROWS=10000
LIFO_CSV_CHUNK_SIZE=1000

# Scoring Configuration
LIFO_DEFAULT_EXPIRY_WEIGHT=0.5
LIFO_DEFAULT_VELOCITY_WEIGHT=0.3
LIFO_DEFAULT_MARGIN_WEIGHT=0.2
LIFO_ENABLE_ML_SCORING=False

# Database Pool Settings
LIFO_DATABASE_POOL_SIZE=5
LIFO_DATABASE_MAX_OVERFLOW=10

# File Paths
LIFO_MODEL_PATH=models/
LIFO_DATA_PATH=data/
LIFO_LOG_PATH=logs/

# External Services (future)
# WEATHER_API_KEY=your_weather_api_key
# GOOGLE_PLACES_API_KEY=your_google_places_key