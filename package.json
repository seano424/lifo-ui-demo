{
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:all": "npm run dev & npm run api:dev",
    "build": "next build",
    "start": "next start",
    "email": "email dev",
    "check": "biome check . && tsc --noEmit",
    "check:fix": "biome check --write . && tsc --noEmit",
    "format": "biome format --write .",
    "api:check": "python3 -m ruff check lifo_ai_core lifo_api && python3 -m ruff format --check lifo_ai_core lifo_api && python3 -m mypy lifo_ai_core lifo_api --show-error-codes --pretty",
    "api:check:fix": "python3 -m ruff check --fix lifo_ai_core lifo_api && python3 -m ruff format lifo_ai_core lifo_api",
    "api:type-check": "python3 -m mypy lifo_ai_core lifo_api --show-error-codes --pretty",
    "api:dev": "cd lifo_api && python3 -m uvicorn app.main:app --reload --port 8000",
    "api:start": "cd lifo_api && python3 -m uvicorn app.main:app --port 8000 --host 0.0.0.0 --workers 4",
    "api:install": "cd lifo_api && pip install -r requirements.txt",
    "supabase": "supabase",
    "supabase:login": "supabase login",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "update-types": "npx supabase gen types typescript --project-id jrgmetdsohowtxickqij --schema user_mgmt,timeseries,scoring,inventory,business,analytics,public > types/supabase.ts"
  },
