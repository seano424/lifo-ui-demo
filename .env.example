# =============================================================================
# LIFO AI ENGINE - UNIFIED ENVIRONMENT CONFIGURATION
# =============================================================================
# SECURITY WARNING: This is a template file with placeholder values
# 1. Copy this file to .env.local 
# 2. Replace ALL placeholder values with actual credentials
# 3. DO NOT commit .env.local with real credentials
# 4. Add .env.local to .gitignore
#
# This unified file replaces separate .env files for frontend and backend
# Both Next.js and FastAPI read from the same environment configuration
# =============================================================================

# =============================================================================
# SUPABASE CONFIGURATION (Shared)
# =============================================================================
# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api

# Frontend (Public) - Exposed to client-side code
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend (Private) - FastAPI Environment Variables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-key
SUPABASE_DB_PASSWORD=your-db-password

# Resend
RESEND_API=your-resend-api-key
# SECRET KEY
SECRET_KEY=YOUR_SECRET_KEY_REPLACE_THIS_WITH_SECURE_RANDOM_STRING

MANUAL_ACCESS_TOKEN=...

# Database Configuration (using Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# =============================================================================
# APPLICATION SETTINGS (Shared)
# =============================================================================
APP_NAME=LIFO AI Engine
APP_VERSION=1.0.0
# 🔧 SET THIS TO SWITCH ENVIRONMENTS:
#    development = local API (localhost:8000)
#    staging     = staging API (DigitalOcean)
ENVIRONMENT=development
NEXT_PUBLIC_ENVIRONMENT=development

# Development Logging
# Control console output verbosity - both default to false for clean console
# NEXT_PUBLIC_DEBUG: Show all debug logs (auth events, general app flow)
# NEXT_PUBLIC_DEBUG_OCR: Show OCR-specific debug logs (image capture, API calls, processing)
# NEXT_PUBLIC_LOG_QUERIES: Show database queries, API calls, and performance metrics
# Note: Errors always show regardless of these settings
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_DEBUG_OCR=false
NEXT_PUBLIC_LOG_QUERIES=false

# Feature Flags
# NEXT_PUBLIC_AUTO_OCR_ENABLED: Enable automatic OCR scanning for expiry dates
# true  = Auto-scan every 500ms (hands-free experience)
# false = Manual capture with button click (user-controlled)
NEXT_PUBLIC_AUTO_OCR_ENABLED=false

DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# CORS Settings (Development) - Using defaults from config.py
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Security
# ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,lifo-api-dev.local,testserver

# AI Scoring Configuration
SCORING_WEIGHTS_EXPIRY=0.5
SCORING_WEIGHTS_VELOCITY=0.3
SCORING_WEIGHTS_MARGIN=0.2

# MVP Mobile Performance Settings
MOBILE_CACHE_TTL=300
MOBILE_PERFORMANCE_THRESHOLD_MS=500
SCAN_WORKFLOW_RATE_LIMIT=30
REALTIME_QUEUE_SIZE=1000

# Rate Limiting Configuration
RATE_LIMIT_STORAGE_URL=memory://
RATE_LIMIT_ENABLED=true

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=csv,xlsx,jpg,jpeg,png

# Cache Configuration (using in-memory for development)
CACHE_TTL=300
CACHE_ENABLED=true

# =============================================================================
# FRONTEND CONFIGURATION (Next.js)
# =============================================================================

# API Integration (automatically set based on ENVIRONMENT variable above)
# development = http://localhost:8000
# staging = https://lifo-ai-api-staging-d5tjh.ondigitalocean.app
FASTAPI_URL=http://localhost:8000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
# FASTAPI_API_KEY not needed for local development

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# Google Places API (Optional - uncomment if needed)
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_api_key_here

# Development Features
ENABLE_DOCS=true
ENABLE_REDOC=true
ENABLE_OPENAPI=true

# FastAPI Integration (now working!)
ENABLE_FASTAPI=true


# =============================================================================
# GOOGLE CLOUD VISION API CONFIGURATION
# =============================================================================

# Google Cloud Vision API
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# Note: Use Application Default Credentials (ADC) for authentication
# Do NOT set GOOGLE_APPLICATION_CREDENTIALS in development
# Run: gcloud auth application-default login

# Vision API Settings
VISION_API_TIMEOUT=10000  # milliseconds
VISION_MAX_IMAGE_SIZE=15728640  # 15MB in bytes
VISION_SUPPORTED_FORMATS=jpeg,jpg,png,webp

# OCR Processing Thresholds
OCR_CONFIDENCE_THRESHOLD=0.7
BARCODE_CONFIDENCE_THRESHOLD=0.8
EXPIRY_CONFIDENCE_THRESHOLD=0.65
MAX_PROCESSING_TIME_MS=10000

# Auto-OCR Pre-Check Thresholds (Client-Side Frame Analysis)
# These control when the client-side scanner triggers an OCR API call
# Lower values = more sensitive (triggers more easily, more API calls)
# Higher values = stricter (fewer false triggers, fewer API calls)
NEXT_PUBLIC_AUTO_OCR_MIN_TEXT_CONFIDENCE=0.05      # Min text detection confidence (0-1, default: 0.05 for low-light handwritten text)
NEXT_PUBLIC_AUTO_OCR_MIN_DATE_CONFIDENCE=0.35      # Min date pattern confidence (0-1, default: 0.35 to catch formats like "JAN2025")
NEXT_PUBLIC_AUTO_OCR_MIN_OVERALL_SCORE=0.5         # Min overall frame quality score (0-1, default: 0.5)
NEXT_PUBLIC_AUTO_OCR_MIN_SHARPNESS=0.01            # Min sharpness/focus (0-1, default: 0.01 for handwritten text on paper)

# Image Recognition Settings
IMAGE_UPLOAD_MAX_SIZE=10485760  # 10MB
IMAGE_ALLOWED_TYPES=jpg,jpeg,png,webp


# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 
# Production Deployment:
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=false
# 3. Update all URLs to production domains
# 4. Use strong SECRET_KEY (generate with: openssl rand -hex 32)
# 5. Set proper CORS_ORIGINS for your domain
# 6. Configure production database
# 7. Set up proper SMTP for email delivery
#
# Security Checklist:
# ✓ All placeholder values replaced
# ✓ .env.local added to .gitignore
# ✓ Service role keys secured
# ✓ JWT secrets are strong random strings
# ✓ Production URLs configured
# ✓ CORS origins restricted to your domains
#
# =============================================================================