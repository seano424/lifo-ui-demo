# =============================================================================
# LIFO AI FRONTEND - ENVIRONMENT CONFIGURATION
# Next.js 15 Frontend Application
# =============================================================================
# SECURITY WARNING: This is a template file with placeholder values
# 1. Copy this file to .env.local (Next.js convention)
# 2. Replace ALL placeholder values with actual credentials
# 3. DO NOT commit .env.local with real credentials
# 4. Ensure .env.local is in .gitignore
#
# IMPORTANT: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# Never put secrets in NEXT_PUBLIC_ variables!
# =============================================================================

# =============================================================================
# SUPABASE CONFIGURATION (Frontend)
# =============================================================================
# Get these from: https://app.supabase.com/project/_/settings/api

# Public Variables (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side Only (for Next.js API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================
# URL to your FastAPI backend (lifo-api repository)

# Development (local backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Staging (when using deployed backend)
# NEXT_PUBLIC_API_URL=https://lifo-ai-api-staging.ondigitalocean.app

# Production (when using production backend)
# NEXT_PUBLIC_API_URL=https://api.lifo.ai

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment indicator
NEXT_PUBLIC_ENVIRONMENT=development

# App Info
NEXT_PUBLIC_APP_NAME=LIFO AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Control console output verbosity - all default to false for clean console

# Show all debug logs (auth events, general app flow)
NEXT_PUBLIC_DEBUG=false

# Show OCR-specific debug logs (image capture, API calls, processing)
NEXT_PUBLIC_DEBUG_OCR=false

# Show batch action and scan-out debug logs (inventory operations, donations)
NEXT_PUBLIC_DEBUG_ACTIONS=false

# Show database queries, API calls, and performance metrics
NEXT_PUBLIC_LOG_QUERIES=false

# Note: Errors always show regardless of these settings

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable dark mode system support
# true  = Respect system theme preferences (light/dark mode)
# false = Light mode only (default for production)
NEXT_PUBLIC_ENABLE_DARK_MODE=false

# Enable automatic OCR scanning for expiry dates
# true  = Auto-scan every 500ms (hands-free experience)
# false = Manual capture with button click (user-controlled)
NEXT_PUBLIC_AUTO_OCR_ENABLED=false

# Auto-OCR Pre-Check Thresholds (Client-Side Frame Analysis)
# These control when the client-side scanner triggers an OCR API call
# Lower values = more sensitive (triggers more easily, more API calls)
# Higher values = stricter (fewer false triggers, fewer API calls)
# NOTE: Text confidence is NOT a hard requirement - it contributes 30% to the overall score only
NEXT_PUBLIC_AUTO_OCR_MIN_TEXT_CONFIDENCE=0.05      # Only used in overall score calculation (30% weight) - NOT a hard threshold
NEXT_PUBLIC_AUTO_OCR_MIN_DATE_CONFIDENCE=0.35      # Min date pattern confidence (0-1) - HARD requirement
NEXT_PUBLIC_AUTO_OCR_MIN_OVERALL_SCORE=0.30        # Min overall score (0-1) - combines text, date, sharpness, contrast - HARD requirement
NEXT_PUBLIC_AUTO_OCR_MIN_SHARPNESS=0.005           # Min sharpness/focus (0-1) - HARD requirement

# =============================================================================
# EMAIL CONFIGURATION (Next.js API Routes)
# =============================================================================
# Resend API Key (for sending emails from Next.js)
RESEND_API_KEY=your-resend-api-key-here

# =============================================================================
# GOOGLE SERVICES (Optional)
# =============================================================================
# Google Places API (for store location autocomplete)
# Uncomment and add your key if needed
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-api-key

# =============================================================================
# INTERNATIONALIZATION
# =============================================================================
# Default locale (en, fr, nl)
NEXT_PUBLIC_DEFAULT_LOCALE=en

# =============================================================================
# ANALYTICS & MONITORING (Optional)
# =============================================================================
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog
NEXT_PUBLIC_POSTHOG_API_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (Error Tracking)
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# These are typically set by your hosting provider
# Vercel/Netlify will set these automatically

# Public URL of your frontend
# NEXT_PUBLIC_SITE_URL=https://app.lifo.ai

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# Development Setup:
# 1. Copy this file: cp .env.example .env.local
# 2. Update Supabase credentials (URL and anon key)
# 3. Set NEXT_PUBLIC_API_URL to your backend URL
# 4. Configure other services as needed (Resend, Google Places, etc.)
#
# Production Deployment:
# 1. Set NEXT_PUBLIC_ENVIRONMENT=production
# 2. Update NEXT_PUBLIC_API_URL to production backend
# 3. Update NEXT_PUBLIC_SUPABASE_URL to production Supabase
# 4. Set NEXT_PUBLIC_SITE_URL to your production domain
# 5. Disable all debug flags (set to false)
# 6. Configure analytics and monitoring
# 7. Ensure all NEXT_PUBLIC_ variables are safe to expose
#
# Security Checklist:
# ✓ All placeholder values replaced
# ✓ .env.local added to .gitignore
# ✓ No secrets in NEXT_PUBLIC_ variables
# ✓ Service role key secured (not exposed to browser)
# ✓ Production URLs configured correctly
# ✓ Debug flags disabled in production
# ✓ No credentials committed to git
#
# Next.js Environment Variable Docs:
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
#
# =============================================================================
