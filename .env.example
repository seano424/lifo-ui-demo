# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_DB_PASSWORD=
SUPABASE_JWT_SECRET=

# Resend
RESEND_API=

# FastAPI Integration
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
FASTAPI_URL=http://localhost:8000  # For server-side calls

# If FastAPI needs auth
FASTAPI_API_KEY=your_api_key_here

# Google Places API
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_api_key_here


# Testing onboarding flow
# Can be 'mock', 'test', 'production'
# mock => No database changes
# test => Real database with current user
# production => Full signup flow / Default mode
ONBOARDING_MODE=test
# options for onboarding mode=test/mock/production
