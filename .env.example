# =============================================================================
# LIFO AI ENGINE - UNIFIED ENVIRONMENT CONFIGURATION
# =============================================================================
# SECURITY WARNING: This is a template file with placeholder values
# 1. Copy this file to .env.local 
# 2. Replace ALL placeholder values with actual credentials
# 3. DO NOT commit .env.local with real credentials
# 4. Add .env.local to .gitignore
#
# This unified file replaces separate .env files for frontend and backend
# Both Next.js and FastAPI read from the same environment configuration
# =============================================================================

# =============================================================================
# SUPABASE CONFIGURATION (Shared)
# =============================================================================
# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api

# Frontend (Public) - Exposed to client-side code
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend (Private) - Server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-key
SUPABASE_DB_PASSWORD=your-db-password

# Database Connection
DATABASE_URL=postgresql+asyncpg://your-username:your-password@your-host:5432/your-database

# =============================================================================
# APPLICATION SETTINGS (Shared)
# =============================================================================
APP_NAME=LIFO AI Engine
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# FRONTEND CONFIGURATION (Next.js)
# =============================================================================

# API Integration
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
FASTAPI_URL=http://localhost:8000  # For server-side calls
FASTAPI_BASE_URL=http://localhost:8000  # Base URL for FastAPI scoring integration
FASTAPI_API_KEY=your_api_key_here

# Scoring Integration
ENABLE_AUTO_SCORING=true  # Set to false to disable automatic scoring after batch creation (server-side)
NEXT_PUBLIC_ENABLE_AUTO_SCORING=true  # Set to false to disable automatic scoring (client-side)

# Google Places API (Optional)
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_api_key_here

# Resend Email API
RESEND_API=your-resend-api-key

# Onboarding Flow Configuration
# Options: 'mock', 'test', 'production'
# mock => No database changes
# test => Real database with current user  
# production => Full signup flow (default)
ONBOARDING_MODE=test

# =============================================================================
# BACKEND CONFIGURATION (FastAPI)
# =============================================================================

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Frontend Integration
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# CORS Settings (Development)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Security
SECRET_KEY=YOUR_SECRET_KEY_REPLACE_THIS_WITH_SECURE_RANDOM_STRING
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Pool Configuration
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# =============================================================================
# AI/ML CONFIGURATION
# =============================================================================

# Google Cloud Vision API
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# Note: Use Application Default Credentials (ADC) for authentication
# Do NOT set GOOGLE_APPLICATION_CREDENTIALS in development
# Run: gcloud auth application-default login

# Vision API Settings
VISION_API_TIMEOUT=10000  # milliseconds
VISION_MAX_IMAGE_SIZE=15728640  # 15MB in bytes
VISION_SUPPORTED_FORMATS=jpeg,jpg,png,webp

# OCR Processing Thresholds
OCR_CONFIDENCE_THRESHOLD=0.7
BARCODE_CONFIDENCE_THRESHOLD=0.6
EXPIRY_CONFIDENCE_THRESHOLD=0.65
MAX_PROCESSING_TIME_MS=10000

# Scoring Algorithm Configuration
SCORING_WEIGHTS_EXPIRY=0.5
SCORING_WEIGHTS_VELOCITY=0.3
SCORING_WEIGHTS_MARGIN=0.2

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Cache Configuration (Redis)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# Monitoring & Metrics
ENABLE_METRICS=false
METRICS_PORT=9090

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=csv,xlsx

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@lifoai.com

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Test Database (Optional)
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# Development Tools
ENABLE_DEBUG_TOOLBAR=true
ENABLE_SQL_LOGGING=false

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 
# Production Deployment:
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=false
# 3. Update all URLs to production domains
# 4. Use strong SECRET_KEY (generate with: openssl rand -hex 32)
# 5. Set proper CORS_ORIGINS for your domain
# 6. Configure production database
# 7. Set up proper SMTP for email delivery
#
# Security Checklist:
# ✓ All placeholder values replaced
# ✓ .env.local added to .gitignore
# ✓ Service role keys secured
# ✓ JWT secrets are strong random strings
# ✓ Production URLs configured
# ✓ CORS origins restricted to your domains
#
# =============================================================================