# =============================================================================
#Lifo AI FRONTEND - ENVIRONMENT CONFIGURATION
# Next.js 15 Frontend Application
# =============================================================================
# SECURITY WARNING: This is a template file with placeholder values
# 1. Copy this file to .env.local (Next.js convention)
# 2. Replace ALL placeholder values with actual credentials
# 3. DO NOT commit .env.local with real credentials
# 4. Ensure .env.local is in .gitignore
#
# IMPORTANT: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# Never put secrets in NEXT_PUBLIC_ variables!
# =============================================================================

# =============================================================================
# ENVIRONMENT SELECTION - BACKEND API
# =============================================================================
# 🔧 INSTRUCTIONS: Uncomment ONE section below to switch environments
# - Comment out the sections you're NOT using with #
# - Only ONE section should be active at a time
# =============================================================================

NEXT_PUBLIC_ENABLE_DEV_TOOLS=true

# ✅ DEVELOPMENT (Local Backend)
# Uncomment these 4 lines for local backend development:
ENVIRONMENT=development
NEXT_PUBLIC_ENVIRONMENT=development
FASTAPI_URL=http://127.0.0.1:8000
NEXT_PUBLIC_FASTAPI_URL=http://127.0.0.1:8000

# ✅ STAGING (Remote Backend)
# Uncomment these 4 lines for staging environment:
# ENVIRONMENT=staging
# NEXT_PUBLIC_ENVIRONMENT=staging
# FASTAPI_URL=https://your-staging-api.ondigitalocean.app
# NEXT_PUBLIC_FASTAPI_URL=https://your-staging-api.ondigitalocean.app

# ❌ PRODUCTION (Production Backend)
# Uncomment these 4 lines for production environment:
# ENVIRONMENT=production
# NEXT_PUBLIC_ENVIRONMENT=production
# FASTAPI_URL=https://api.lifo.ai
# NEXT_PUBLIC_FASTAPI_URL=https://api.lifo.ai

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=LIFO AI Engine
APP_VERSION=1.0.0

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# 🔧 INSTRUCTIONS: Uncomment ONE section below to switch between local/remote
# - Comment out the section you're NOT using with #
# - Only ONE section should be active at a time
# =============================================================================

# ✅ LOCAL SUPABASE (Run `supabase start` first)
# These are standard demo keys - same for all local Supabase instances (never change)
# Uncomment these 3 lines for local development:
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ✅ REMOTE SUPABASE (Production/Staging)
# Get these from: https://app.supabase.com/project/_/settings/api
# Uncomment these 3 lines for remote Supabase:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# WEBHOOKS & BACKEND INTEGRATION
# =============================================================================
# Authentication for backend API calls (uses Supabase service role key)
FASTAPI_API_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# Webhook verification (used by Next.js API routes to verify Supabase webhooks)
# Generate a secure random string for production
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-here

# =============================================================================
# EMAIL CONFIGURATION (Next.js API Routes)
# =============================================================================
# Resend API Key (for sending emails from Next.js)
# Get your key from: https://resend.com/api-keys
RESEND_API=your-resend-api-key-here

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Control console output verbosity - all default to false for clean console

# Show all debug logs (auth events, general app flow)
NEXT_PUBLIC_DEBUG=false

# Show OCR-specific debug logs (image capture, API calls, processing)
NEXT_PUBLIC_DEBUG_OCR=false

# Show batch action and scan-out debug logs (inventory operations, donations)
NEXT_PUBLIC_DEBUG_ACTIONS=false

# Show database queries, API calls, and performance metrics
NEXT_PUBLIC_LOG_QUERIES=false

# Note: Errors always show regardless of these settings

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable dark mode system support
# true  = Respect system theme preferences (light/dark mode)
# false = Light mode only (default for production)
NEXT_PUBLIC_ENABLE_DARK_MODE=false

# Enable automatic OCR scanning for expiry dates
# true  = Auto-scan every 500ms (hands-free experience)
# false = Manual capture with button click (user-controlled)
NEXT_PUBLIC_AUTO_OCR_ENABLED=false

# Auto-OCR Pre-Check Thresholds (Client-Side Frame Analysis)
# These control when the client-side scanner triggers an OCR API call
# Lower values = more sensitive (triggers more easily, more API calls)
# Higher values = stricter (fewer false triggers, fewer API calls)
NEXT_PUBLIC_AUTO_OCR_MIN_TEXT_CONFIDENCE=0.05      # Contributes to overall score (30% weight)
NEXT_PUBLIC_AUTO_OCR_MIN_DATE_CONFIDENCE=0.35      # Min date pattern confidence (0-1)
NEXT_PUBLIC_AUTO_OCR_MIN_OVERALL_SCORE=0.30        # Min overall score (0-1)
NEXT_PUBLIC_AUTO_OCR_MIN_SHARPNESS=0.005           # Min sharpness/focus (0-1)

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
# PostHog Analytics (Optional)
# Get your key from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics (Optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking (Optional)
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# =============================================================================
# INTERNATIONALIZATION
# =============================================================================
# Default locale (en, fr, nl)
NEXT_PUBLIC_DEFAULT_LOCALE=en

# =============================================================================
# SUPPORT & CONTACT
# =============================================================================
# Support email address for user help
NEXT_PUBLIC_SUPPORT_EMAIL=support@lifo.ai

# =============================================================================
# DEPLOYMENT CONFIGURATION (Optional)
# =============================================================================
# These are typically set by your hosting provider
# Vercel/Netlify will set these automatically

# Public URL of your frontend
# NEXT_PUBLIC_SITE_URL=https://app.lifo.ai

# =============================================================================
# GOOGLE SERVICES (Optional)
# =============================================================================
# Google Places API (for store location autocomplete)
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-api-key

# =============================================================================
# GOOGLE OAUTH (Sign in with Google)
# =============================================================================
# These credentials are configured in Supabase Dashboard for remote environments
# For local development, add these to enable Google Sign-In:
# Get these from: https://console.cloud.google.com/apis/credentials
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# Development Setup:
# 1. Copy this file: cp .env.example .env.local
# 2. Choose your environment by uncommenting the appropriate sections:
#    - Backend: DEVELOPMENT (local) / STAGING / PRODUCTION
#    - Supabase: LOCAL / REMOTE
# 3. Update credentials for remote services (Supabase, Resend, etc.)
# 4. Configure optional services as needed (PostHog, Google Places, etc.)
#
# Local Development (Recommended for New Developers):
# 1. Start local Supabase: supabase start
# 2. Use LOCAL SUPABASE section (already uncommented in this example)
# 3. Use DEVELOPMENT backend section (for local backend)
# 4. Run: npm run dev
#
# Production Deployment:
# 1. Set ENVIRONMENT=production
# 2. Update NEXT_PUBLIC_FASTAPI_URL to production backend
# 3. Update NEXT_PUBLIC_SUPABASE_URL to production Supabase
# 4. Set NEXT_PUBLIC_SITE_URL to your production domain
# 5. Disable all debug flags (set to false)
# 6. Configure analytics and monitoring
# 7. Ensure all NEXT_PUBLIC_ variables are safe to expose
#
# Security Checklist:
# ✓ All placeholder values replaced
# ✓ .env.local added to .gitignore
# ✓ No secrets in NEXT_PUBLIC_ variables
# ✓ Service role key secured (not exposed to browser)
# ✓ Production URLs configured correctly
# ✓ Debug flags disabled in production
# ✓ No credentials committed to git
#
# =============================================================================
# BACKEND CONFIGURATION NOTE
# =============================================================================
# Backend Configuration: The FastAPI backend has its own .env file in the
# lifo-api repository (https://github.com/lifo-ai/lifo-api). Backend-specific
# variables like DATABASE_URL, GOOGLE_CLOUD_PROJECT_ID, OCR settings, etc.
# should be configured there, not in this frontend .env file.
# =============================================================================

# =============================================================================
# TESTING UTILITIES
# =============================================================================
# Test email templates in different languages:
# Test in English:
# curl "http://localhost:3000/api/test-email?email=your-email@example.com&lang=en&type=welcome"
# Test in French:
# curl "http://localhost:3000/api/test-email?email=your-email@example.com&lang=fr&type=welcome"
# Test in Dutch:
# curl "http://localhost:3000/api/test-email?email=your-email@example.com&lang=nl&type=welcome"

# Supabase CLI utilities:
# supabase status       # Check local Supabase status
# supabase db reset     # Reset local database
# supabase db pull      # Pull schema from remote
