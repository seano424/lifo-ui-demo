# =============================================================================
# LIFO.AI - UPDATED ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env.local and replace ALL placeholder values
# Based on comprehensive codebase analysis - includes ALL used variables
# =============================================================================

# =============================================================================
# ⚠️  CRITICAL VARIABLES (Required for basic functionality)
# =============================================================================

# Supabase Authentication & Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Application Core
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-replace-this-in-production

# Google Cloud Vision API (for OCR functionality)
# Choose ONE of the following methods:
# Method 1: JSON credentials (recommended for cloud deployment)
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project",...}
# Method 2: File path (for local development)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# =============================================================================
# 🌐 FRONTEND CONFIGURATION (Next.js)
# =============================================================================

# FastAPI Backend Integration
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
FASTAPI_URL=http://localhost:8000
FASTAPI_BASE_URL=http://localhost:8000
FASTAPI_API_KEY=your-api-key-if-needed

# Feature Toggles
ENABLE_AUTO_SCORING=true
NEXT_PUBLIC_ENABLE_AUTO_SCORING=true
ENABLE_FASTAPI=true

# Optional: Base URL for production
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Development Flags
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_DISABLE_DEV_SCORING=false

# =============================================================================
# ⚙️  BACKEND CONFIGURATION (FastAPI)
# =============================================================================

# Server Settings
API_HOST=0.0.0.0
API_PORT=8000
API_V1_STR=/api/v1
PROJECT_NAME=LIFO AI API
APP_VERSION=1.0.0

# Security & CORS
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_SECRET_KEY=your-jwt-secret-for-internal-use

# Database Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_DETAILED_REQUEST_LOGGING=false
ENABLE_ALERTING=false
RATE_LIMIT_ENABLED=false

# =============================================================================
# 🤖 AI/ML CONFIGURATION
# =============================================================================

# OCR Processing Settings
VISION_API_TIMEOUT=10000
VISION_MAX_IMAGE_SIZE=15728640
VISION_SUPPORTED_FORMATS=jpeg,jpg,png,webp

# OCR Confidence Thresholds
OCR_CONFIDENCE_THRESHOLD=0.7
BARCODE_CONFIDENCE_THRESHOLD=0.6
EXPIRY_CONFIDENCE_THRESHOLD=0.65
MAX_PROCESSING_TIME_MS=10000

# Scoring Algorithm Weights
SCORING_WEIGHTS_EXPIRY=0.5
SCORING_WEIGHTS_VELOCITY=0.3
SCORING_WEIGHTS_MARGIN=0.2

# =============================================================================
# 📧 EMAIL SERVICES
# =============================================================================

# Resend API (Primary email service)
RESEND_API=re_YourResendAPIKey

# Alternative SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# 🔧 OPTIONAL SERVICES
# =============================================================================

# Google Places API (for store location features)
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSyC...

# Caching (Redis)
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=300

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=csv,xlsx

# Monitoring & Metrics
ENABLE_METRICS=false
METRICS_PORT=9090
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# 🧪 DEVELOPMENT & TESTING
# =============================================================================

# Test Database
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# Development Tools
ENABLE_DEBUG_TOOLBAR=true
ENABLE_SQL_LOGGING=false
SEED_TEST_DATA=false

# Onboarding Configuration
ONBOARDING_MODE=test  # mock, test, production

# Test Authentication (for running tests)
# MANUAL_ACCESS_TOKEN=your-test-token
# DEV_USER_EMAIL=dev@example.com
# DEV_USER_PASSWORD=dev-password

# =============================================================================
# 🔧 DEPLOYMENT SPECIFIC
# =============================================================================

# Workers (for production)
WORKERS=1
MAX_WORKERS=2

# Optional Supabase DB Password
# SUPABASE_DB_PASSWORD=your-database-password

# Additional URLs for production
# FRONTEND_URL=https://your-frontend-domain.com
# API_URL=https://your-api-domain.com

# =============================================================================
# 📝 NOTES & INSTRUCTIONS
# =============================================================================

# 1. SECURITY CHECKLIST:
#    ✓ Replace ALL placeholder values with real credentials
#    ✓ Add .env.local to .gitignore (already done)
#    ✓ Never commit this file with real credentials
#    ✓ Use different keys for development/staging/production

