# Production Environment Variables for LIFO AI FastAPI Backend
# Copy this file to .env.production and fill in the values
# DO NOT commit this file with actual values to git

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=production
DEBUG=false
API_V1_STR=/api/v1
PROJECT_NAME=LIFO AI API

# Server Configuration  
HOST=0.0.0.0
PORT=8080

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Primary Database URL (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# CORS & FRONTEND CONFIGURATION
# =============================================================================
# Production frontend URLs (comma-separated)
BACKEND_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
FRONTEND_URL=https://your-domain.com
API_URL=https://your-api-domain.com

# =============================================================================
# GOOGLE CLOUD CONFIGURATION (Optional)
# =============================================================================
# Google Cloud Vision API (if using)
GOOGLE_APPLICATION_CREDENTIALS_JSON=base64-encoded-service-account-json

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================
REDIS_URL=redis://user:password@host:port/db

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
LOG_LEVEL=INFO
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
WORKERS=2
MAX_WORKERS=4

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# =============================================================================
# DIGITAL OCEAN SPECIFIC
# =============================================================================
# These are automatically set by Digital Ocean App Platform
# _APP_NAME=lifo-ai-api
# _IS_PRODUCTION=true